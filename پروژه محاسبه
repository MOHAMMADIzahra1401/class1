class DFASimulator:
    def init(self, states, alphabet, transitions, start_state, final_states):
        """
        Initialize the DFA components:
        - states: Set of all states (Q)
        - alphabet: Set of allowed input symbols (Sigma)
        - transitions: Nested dictionary representing the transition function (Delta)
        - start_state: The initial state (q0)
        - final_states: Set of accepting states (F)
        """
        self.states = set(states)
        self.alphabet = set(alphabet)
        self.transitions = transitions
        self.start_state = start_state
        self.final_states = set(final_states)

    def evaluate(self, input_string):
        """
        Evaluates the input string character by character from left to right.
        """
        current_state = self.start_state
        print(f"\n--- Starting DFA Evaluation for: '{input_string}' ---")
        print(f"Start State: {current_state}")
        print("-" * 40)

        # Read characters one by one from left to right
        for index, char in enumerate(input_string, 1):
            # Check if character belongs to the alphabet
            if char not in self.alphabet:
                print(f"Error at step {index}: Character '{char}' is NOT in alphabet!")
                return "Reject"
            
            # Find the next state using the transition function
            if current_state in self.transitions and char in self.transitions[current_state]:
                next_state = self.transitions[current_state][char]
                print(f"Step {index}: {current_state} ==({char})==> {next_state}")
                current_state = next_state
            else:
                # Dead-end or undefined transition
                print(f"Error at step {index}: No transition from {current_state} with '{char}'")
                return "Reject"

        print("-" * 40)
        print(f"Final State: {current_state}")
        
        # Check if the final state is an accepting state
        if current_state in self.final_states:
            print("Result: Accept")
            return "Accept"
        else:
            print("Result: Reject")
            return "Reject"


