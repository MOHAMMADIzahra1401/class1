if name == "__main__":
    # Define a sample DFA that accepts strings with an EVEN number of 'b's
    Q = {"q0", "q1"}
    Sigma = {"a", "b"}
    
    # Transition function definition
    Delta = {
        "q0": {"a": "q0", "b": "q1"},
        "q1": {"a": "q1", "b": "q0"}
    }
    
    q0 = "q0"  # Start state
    F = {"q0"} # Final states (Even number of b's lands back on q0)

    # Instantiate the simulator
    dfa = DFASimulator(states=Q, alphabet=Sigma, transitions=Delta, start_state=q0, final_states=F)

    # Test Case 1: Expected to Accept (two 'b's)
    test_string_1 = "abab"
    result_1 = dfa.evaluate(test_string_1)
    print(f"Final Output: {result_1}")

    # Test Case 2: Expected to Reject (three 'b's)
    test_string_2 = "bbab"
    result_2 = dfa.evaluate(test_string_2)
    print(f"Final Output: {result_2}")










