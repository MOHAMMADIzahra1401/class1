    # Let's define an NFA components
    # States: q0, q1, q2
    # Alphabet: a, b
    # Epsilon is represented by '_'
    
    Q = {"q0", "q1", "q2"}
    Sigma = {"a", "b"}
    
    # Transition function table:
    # q0 with 'a' can stay at q0 or go to q1
    # q1 with 'b' goes to q2
    # q0 has an epsilon (_) transition to q2 (just for testing epsilon)
    Delta = {
        "q0": {"a": {"q0", "q1"}, "_": {"q2"}},
        "q1": {"b": {"q2"}},
        "q2": {"b": {"q2"}}
    }
    
    q0 = "q0"
    F = {"q2"} # Accepting state

    # Create NFA Simulator instance
    nfa = NFASimulator(states=Q, alphabet=Sigma, transitions=Delta, start_state=q0, final_states=F)

    # Test Case 1: Testing a valid string
    test_str_1 = "ab"
    result_1 = nfa.evaluate(test_str_1)
    print(f"Final Outcome for '{test_str_1}': {result_1}")

    # Test Case 2: Testing an invalid string
    test_str_2 = "ba"
    result_2 = nfa.evaluate(test_str_2)
